# Puerto donde escucha el servidor Express
PORT=5000

# Ruta absoluta a bot_state.db del bot Python
# Por defecto se resuelve automáticamente subiendo directorios desde src/
BOT_DB_PATH=C:/BOT-MT5/bot_state.db

# Token secreto para autenticar las peticiones de la app móvil.
# Genera uno con: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Copia el MISMO valor en artifacts/mobile/.env como EXPO_PUBLIC_API_SECRET
API_SECRET=cambia_esto_por_un_token_aleatorio_seguro

# Orígenes permitidos para CORS (separados por coma).
# En producción pon la IP/dominio donde corre el servidor Expo o la APK.
# Deja vacío para bloquear todo en producción.
ALLOWED_ORIGINS=http://localhost:8081,http://192.168.1.130:8081

# Nivel de log: trace | debug | info | warn | error
LOG_LEVEL=info
