# URL base del servidor Express (IP LAN de tu PC + puerto 5000).
# Debe coincidir con PORT en artifacts/api-server/.env
# Obtener IP: ipconfig  →  busca "Dirección IPv4" de tu Wi-Fi
EXPO_PUBLIC_API_URL=http://192.168.1.X:5000

# Mismo token que API_SECRET en artifacts/api-server/.env
# Tras cambiar este archivo hay que recompilar el APK (scripts\build-apk.bat)
EXPO_PUBLIC_API_SECRET=copia_el_mismo_API_SECRET_del_servidor
