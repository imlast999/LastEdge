# ── Discord ───────────────────────────────────────────────────────────────────
DISCORD_TOKEN=your_discord_bot_token_here
GUILD_ID=your_discord_server_id_here
SIGNALS_CHANNEL_NAME=signals
AUTHORIZED_USER_ID=your_discord_user_id_here

# ── MT5 Credenciales ──────────────────────────────────────────────────────────
MT5_LOGIN=your_mt5_account_number
MT5_PASSWORD=your_mt5_password
MT5_SERVER=your_broker_server_name   # ej: ICMarkets-Demo, Pepperstone-Demo01

# ── Seguridad ─────────────────────────────────────────────────────────────────
KILL_SWITCH=0
MAX_TRADES_PER_DAY=20
MAX_TRADES_PER_PERIOD=5

# ── Auto-Señales ──────────────────────────────────────────────────────────────
AUTOSIGNALS=1
AUTOSIGNAL_INTERVAL=20              # segundos entre escaneos
AUTOSIGNAL_SYMBOLS=EURUSD,XAUUSD,BTCEUR

# ── Auto-Ejecución (OFF para paper trading) ───────────────────────────────────
AUTO_EXECUTE_SIGNALS=0              # 0 = solo señales Discord, 1 = ejecuta órdenes
AUTO_EXECUTE_CONFIDENCE=HIGH

# ── Riesgo ────────────────────────────────────────────────────────────────────
MT5_RISK_PCT=0.5                    # % del balance por trade

# ── Dashboard ─────────────────────────────────────────────────────────────────
DASHBOARD_PORT=5000
DISABLE_DASHBOARD=0
DASHBOARD_HISTORY_HOURS=168         # 7 días de historial

# ── Modo demo ─────────────────────────────────────────────────────────────────
DEMO_MODE=1
DRY_RUN=0
ADVANCED_FILTERS=0
